# ==========================================
# langchain-chat — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# --- Environment ---
# APP_ENV=dev        # dev | test | prod (default: dev)

# --- API Keys ---
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- Config Overrides (LANGCHAIN_ prefix) ---
# These override values from config.yaml and config.{APP_ENV}.yaml.
# __ (double underscore) separates nesting levels:
#   LANGCHAIN_SECTION__KEY=value
#   LANGCHAIN_SECTION__SUBSECTION__KEY=value
#
# LANGCHAIN_STORAGE__TYPE=mysql
# LANGCHAIN_LLM__MODEL=gpt-4o
# LANGCHAIN_LLM__TEMPERATURE=0.5
# LANGCHAIN_LOG__LEVEL=DEBUG
# LANGCHAIN_LOG__FILE=logs/custom.log
# LANGCHAIN_STORAGE__MYSQL__HOST=db.example.com
# LANGCHAIN_STORAGE__MYSQL__PORT=3306
# LANGCHAIN_STORAGE__MYSQL__USER=app_user
# LANGCHAIN_STORAGE__MYSQL__PASSWORD=secret
